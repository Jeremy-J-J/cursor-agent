# Highway curve lane change scenario
# Description: Test vehicle's lane change behavior at highway curve entrance
# Scenario: Ego vehicle changes lanes from outer to inner lane at highway curve entrance

import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"
import "$OSC2LIB/scenarios/free_drive/curved_road/ego_free_drive_on_curved_road.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_free_driving_top.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M499_FTX_suburban.xodr"

scenario sut.highway_curve_lane_change_test inherits project_base_scenario:
    keep(default scenario_str_generic == "highway_curve_lane_change_test")
    
    in_road: one_way_road
    
    # Ego vehicle speed
    ego_speed: speed with:
        keep(default it == 60kph)
    
    # Lane change parameters
    start_lane: int with:
        keep(default it == -2)  # Outer lane
    
    end_lane: int with:
        keep(default it == -1)  # Inner lane
    
    # Distance to curve entrance where lane change starts
    curve_entrance_distance: length with:
        keep(default it == 80m)
    
    # Duration of the test
    duration_time: time with:
        keep(default it == 20s)
    
    # NPC vehicle type
    npc_vehicle_type: vehicle_category with:
        keep(default it == sedan)
    
    do parallel():
        set_up: serial():
            sut.car.drive() with:
                along(in_road)
                
        parallel():
            # Ego vehicle driving on curved road with lane change
            ego_phase: sut.ego_free_drive_on_curved_road() with:
                keep(it.gen_curve_direction == right_curve)
                keep(it.gen_max_radius <= 150m)
                keep(it.gen_min_length >= 120m)
                keep(it.gen_start_offset == 0m)
                keep(it.gen_lane_change_start_distance == curve_entrance_distance)
                keep(it.gen_start_lane == start_lane)
                keep(it.gen_end_lane == end_lane)
                
            # NPC vehicle in the same lane as ego before curve
            npc_phase: sut.npc_free_driving() with:
                keep(it.npc_vehicle_type == self.npc_vehicle_type)
                keep(it.npc_relative_position == curve_entrance_distance - 10m)
                keep(it.npc_initial_speed == ego_speed)
                keep(it.npc_target_speed == ego_speed)
                keep(it.npc_duration == duration_time)
                keep(it.ref_car == sut.car)

extend top.main:
    do sut.highway_curve_lane_change_test()

extend test_additional_parameters:
    const test_index: string

extend test_config:
    set test_name = "highway_curve_lane_change_test"
    set additional_parameters.test_index = "auto_20251126_000000"