import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M499_FTX_suburban.xodr"

extend top.main:
    # T-type intersection scenario for lateral interference collision test
    # Road 1 (horizontal) - main road for ego vehicle
    main_road: one_way_road
    
    # Road 2 (vertical) - side road for interfering vehicle  
    side_road: one_way_road
    
    # Define the junction relationship (T-type intersection)
    top.roads_enter_junction_relation(main_road, side_road, 
        relative_direction: perpendicular)
    
    # Vehicle definitions
    # Ego vehicle (main vehicle)
    ego_car: vehicle
    
    # Side interfering vehicle
    side_vehicle: vehicle
    
    # Adversary vehicle (left turning)
    adversary_vehicle: vehicle
    
    # Yellow vehicle (right side of main road)
    yellow_vehicle: vehicle
    
    # Red vehicle (opposite direction)
    red_vehicle: vehicle
    
    # Static obstacles
    red_obstacle: static_obstacle
    white_obstacle: static_obstacle
    
    # Scenario parameters
    test_speed: speed with:
        keep(test_speed in [20kph..80kph])
    
    # Lane definitions
    ego_lane: int
    side_lane: int
    adversary_lane: int
    yellow_lane: int
    red_lane: int
    
    # Position parameters
    # Ego vehicle starts at s=40 on main road
    ego_start_position: length with:
        keep(ego_start_position == 40m)
    
    # Side vehicle starts at s=40 on side road, same position as ego
    side_start_position: length with:
        keep(side_start_position == 40m)
    
    # Adversary vehicle starts at s=40 on main road (opposite direction)
    adversary_start_position: length with:
        keep(adversary_start_position == 40m)
    
    # Trigger position for adversary vehicle (s=60)
    trigger_position: length with:
        keep(trigger_position == 60m)
    
    # Obstacle positions
    red_obstacle_position: length with:
        keep(red_obstacle_position == 50m)
        
    white_obstacle_position: length with:
        keep(white_obstacle_position == 55m)
    
    # Vehicle speeds
    ego_speed: speed with:
        keep(ego_speed == test_speed)
        
    side_speed: speed with:
        keep(side_speed == test_speed)
        
    adversary_speed: speed with:
        keep(adversary_speed == test_speed)
        
    yellow_speed: speed with:
        keep(yellow_speed == test_speed)
        
    red_speed: speed with:
        keep(red_speed == test_speed)
    
    # Define vehicle behaviors
    do serial():
        # Parallel execution of all vehicles
        sut_to: parallel():
            # Ego vehicle: straight through the intersection
            serial():
                # Ego vehicle drives straight on main road
                ego_drive_straight: ego_car.drive() with:
                    speed(ego_speed, at: start, run_mode: best_effort)
                    lane(ego_lane, at: start)
                    along(main_road, at: start, end_offset: trigger_position)
            
            # Side interfering vehicle: straight on side road
            serial():
                # Side vehicle drives straight on side road
                side_drive_straight: side_vehicle.drive() with:
                    speed(side_speed, at: start, run_mode: best_effort)
                    lane(side_lane, at: start)
                    along(side_road, at: start, end_offset: side_start_position)
            
            # Adversary vehicle: left turn at intersection
            serial():
                # Adversary vehicle drives straight then turns left at trigger position
                adversary_drive_straight: adversary_vehicle.drive() with:
                    speed(adversary_speed, at: start, run_mode: best_effort)
                    lane(adversary_lane, at: start)
                    along(main_road, at: start, end_offset: trigger_position)
                
                # Adversary vehicle turns left at trigger position
                adversary_turn_left: adversary_vehicle.drive() with:
                    speed(adversary_speed, at: start, run_mode: best_effort)
                    avoid_collisions(false)  # Allow for collision testing
                    along(main_road, at: start, end_offset: trigger_position)
                    # Left turn maneuver would be defined here
            
            # Yellow vehicle: straight on main road (right side)
            serial():
                # Yellow vehicle drives straight on main road
                yellow_drive_straight: yellow_vehicle.drive() with:
                    speed(yellow_speed, at: start, run_mode: best_effort)
                    lane(yellow_lane, at: start)
                    along(main_road, at: start, end_offset: trigger_position)
            
            # Red vehicle: left turn on opposite road
            serial():
                # Red vehicle drives straight then turns left
                red_drive_straight: red_vehicle.drive() with:
                    speed(red_speed, at: start, run_mode: best_effort)
                    lane(red_lane, at: start)
                    along(main_road, at: start, end_offset: trigger_position)
                
                # Red vehicle turns left at intersection
                red_turn_left: red_vehicle.drive() with:
                    speed(red_speed, at: start, run_mode: best_effort)
                    avoid_collisions(false)  # Allow for collision testing
                    along(main_road, at: start, end_offset: trigger_position)
                    # Left turn maneuver would be defined here
            
            # Static obstacles: red and white triangles
            serial():
                # Red obstacle at position 50m
                red_obstacle.drive() with:
                    position(red_obstacle_position, at: start)
                    # Static obstacle behavior
                
                # White obstacle at position 55m
                white_obstacle.drive() with:
                    position(white_obstacle_position, at: start)
                    # Static obstacle behavior

    # Log information for debugging
    on @ego_drive_straight.start:
        call logger.log_info("Ego vehicle starting position: $(ego_start_position)")
        call logger.log_info("Ego vehicle speed: $(ego_speed)")
        
    on @adversary_drive_straight.start:
        call logger.log_info("Adversary vehicle starting position: $(adversary_start_position)")
        call logger.log_info("Adversary vehicle speed: $(adversary_speed)")
        
    on @trigger_position:
        call logger.log_info("Triggering adversary vehicle left turn at s=$(trigger_position)")