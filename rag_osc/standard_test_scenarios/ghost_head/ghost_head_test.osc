# Ghost head test scenario - pedestrian crossing in front of a truck
# Road scenario: Urban two-lane straight road
# Participants: Ego vehicle (white car), truck, pedestrian (child)
# Initial positions: Ego in inner lane, truck in outer lane stationary, pedestrian behind truck
# Motion: Ego driving at constant speed, truck stationary, pedestrian crossing from back to ego lane
# Ego intention: Straight through intersection
# Trigger condition: Ego drives over 58 meters to trigger pedestrian crossing

import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"
import "$OSC2LIB/scenarios/free_drive/ego_free_drive_auto_gen/ego_free_drive_auto_gen_one_way_road_top.osc"
import "$OSC2LIB/scenarios/free_drive/npc_driving/npc_free_driving_top.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M499_FTX_suburban.xodr"

scenario sut.ghost_head_test_run inherits project_base_scenario:
    keep(default scenario_str_generic == "ghost_head_test_run")
    
    # Test road
    my_road: one_way_road
    
    # Ego vehicle (white car)
    ego_vehicle: vehicle
    
    # Truck (large vehicle)
    truck: vehicle
    keep(truck.vehicle_category == box_truck)
    
    # Pedestrian (child)
    pedestrian: pedestrian
    
    # Ego lane (inner lane)
    ego_lane: int with:
        keep(it in [1, 2])
    
    # Truck lane (outer lane)
    truck_lane: int with:
        keep(it in [1, 2])
        keep(it != ego_lane)
    
    # Start offset
    start_offset: length with:
        keep(it <= my_road.length - 150m)
    
    # Ego speed
    ego_speed: speed with:
        keep(default it == 40kph)
    
    # Truck speed (stationary)
    truck_speed: speed with:
        keep(default it == 0kph)
    
    # Pedestrian speed
    pedestrian_speed: speed with:
        keep(default it == 3kph)
    
    # Distance between truck and pedestrian
    truck_pedestrian_distance: length with:
        keep(default it in [10m..20m])
    
    # Distance between ego and truck
    ego_truck_distance: length with:
        keep(default it in [30m..50m])
    
    # Trigger distance for pedestrian crossing
    trigger_distance: length with:
        keep(default it == 58m)
    
    # Duration of the test
    duration_time: time with:
        keep(it >= 10s)
    
    # Set up the scenario
    keep(sut.car.ftx_driver.bypass_behavior.allow_opposite_left_side == true)

    on @set_up.start:
        call logger.log_info("Ego speed: $(ego_speed)")
        call logger.log_info("Truck speed: $(truck_speed)")
        call logger.log_info("Pedestrian speed: $(pedestrian_speed)")
        call logger.log_info("Ego to truck distance: $(ego_truck_distance)")
        call logger.log_info("Trigger distance: $(trigger_distance)")
        call logger.log_info("Duration time: $(duration_time)")

    do serial():
        set_up: parallel():
            # Ego vehicle driving
            ego_free_drive_phase: sut.ego_free_drive_auto_gen_one_way_road() with:
                keep(it.gen_ego_speed_at_start == ego_speed)
                keep(it.ego_road_element == my_road)
                keep(it.gen_min_lanes == 2)
                keep(it.gen_max_lanes == 2)
                keep(it.gen_ego_lane_at_start == ego_lane)
                keep(it.ego_driving_duration == duration_time)
            
            # Truck driving (stationary)
            truck_driving: sut.npc_free_driving() with:
                keep(it.npc_relative_position == ego_truck_distance)
                keep(it.npc_initial_speed == truck_speed)
                keep(it.npc_target_speed == truck_speed)
                keep(it.npc_duration == duration_time)
                keep(it.npc_initial_lane == truck_lane)
                keep(it.npc_target_lane == truck_lane)
                keep(it.ref_car == sut.car)

extend top.main:
    do sut.ghost_head_test_run()

extend test_additional_parameters:
    const test_index: string

extend test_config:
    set test_name = "ghost_head_test_run"
    set additional_parameters.test_index = "auto_20251120_164500"