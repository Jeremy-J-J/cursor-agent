import "$PROJECT_DIR/projectLibs/project_scenario_base/project_base_scenario_model_ssp.osc"

extend test_config:
    set map = "$OSC2LIB/maps/M781_FTX_Roundabout_4_Legs.xodr"

extend top.main:
    # Roundabout merge scenario
    # Road definitions
    road_12: one_way_road with:
        keep(road_12.id == "Road_12")
    road_6: one_way_road with:
        keep(road_6.id == "Road_6")
    roundabout_entry: roundabout_entry with:
        keep(roundabout_entry.id == "roundabout_entry")
    roundabout_exit: roundabout_exit with:
        keep(roundabout_exit.id == "roundabout_exit")
    roundabout_whole: roundabout_from_entry with:
        keep(roundabout_whole.id == "roundabout_whole")
    internal_road: internal_road_with_conflict with:
        keep(internal_road.id == "internal_road")
    
    # Vehicle definitions
    ego_car: vehicle with:
        keep(ego_car.id == "sut")
    npc_car: vehicle with:
        keep(npc_car.id == "npc")
    
    # Scenario parameters
    test_speed: speed with:
        keep(test_speed in [20kph..80kph])
    
    # Behavior configuration
    keep(sut.car.ftx_driver.bypass_behavior.enable == true)
    
    # Log output
    on @sut_to.start:
        call logger.log_info("road_12.id: $(road_12.id)")
        call logger.log_info("road_6.id: $(road_6.id)")
        call logger.log_info("roundabout_entry.id: $(roundabout_entry.id)")
        call logger.log_info("roundabout_exit.id: $(roundabout_exit.id)")
        call logger.log_info("internal_road.conflicting_road_id: $(internal_road.conflicting_road_id)")
    
    do serial():
        sut_to: parallel():
            # Ego vehicle: entering roundabout and driving around
            serial():
                # Phase 1: From road_12 to roundabout entry
                phase1: sut.car.drive() with:
                    speed(test_speed, at: start, run_mode: best_effort)
                    along(road_12, at: start)
                    along(roundabout_entry, at: start, end_offset: 5m)
                
                # Phase 2: Enter roundabout and drive around
                phase2: sut.car.drive() with:
                    along(roundabout_whole)
                    keep_speed()
            
            # NPC vehicle: driving in roundabout
            serial():
                npc_car.drive() with:
                    speed(test_speed, at: start, run_mode: best_effort)
                    along(internal_road.conflicting_road, at: start)
                    along(roundabout_exit, at: end, run_mode: best_effort)
                    lane(rightmost: true)
                    keep_speed()